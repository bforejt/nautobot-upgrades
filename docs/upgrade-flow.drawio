<mxfile host="app.diagrams.net" type="device">
  <diagram name="IOS-XE upgrade flow" id="iosxe-upgrade-flow">
    <mxGraphModel dx="1000" dy="2000" grid="1" gridSize="10" guides="1" tooltips="1"
