        <mxCell id="cred" value="Resolve credentials&amp;#10;(job override OR device Secrets Group)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="316" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_cred" value="Secrets group +&amp;#10;username &amp; password?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="398" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="reach" value="GET device-system-data&amp;#10;(auth + reachability)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="508" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_reach" value="Reachable &amp;&amp;#10;authenticated?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="590" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="curr" value="Read current version&amp;#10;(from the reachability response)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="700" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_target" value="Already on&amp;#10;target version?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="782" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="avcsup" value="Opt-in: quiet SELinux noise on terminals&amp;#10;(running-config; console + term-mon only;&amp;#10;skipped &gt;=17.18.3; read-first; warn-only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="892" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_floor" value="Version parses&amp;#10;&amp; ≥ 17.9.1?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="974" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="mode" value="Read oper-state boot-mode&amp;#10;(install-oper, all members)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="1084" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_mode" value="All members&amp;#10;INSTALL mode?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="1166" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="img" value="Resolve image (device override →&amp;#10;device-type map → default)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="1276" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_img" value="Image has filename&amp;#10;&amp; download URL?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="1358" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="d_clean" value="Clean device first&amp;#10;ticked? (default off)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="1454" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="space" value="Discover target filesystem + read free&amp;#10;space (fields-scoped partitions reads;&amp;#10;evaluates the CLEANED flash)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="1564" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_space" value="Free ≥ image × 2&amp;#10;(or ≥ 2 GB if size unknown)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="1646" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="d_dry" value="Dry-run?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="1742" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="copy" value="File-listing pre-check (exact size in the&amp;#10;target partition → skip if staged) → classic&amp;#10;copy in worker thread + size-poll progress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="1852" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_size" value="Transfer complete&amp;#10;&amp; size matches?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="1934" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="d_stagecopy" value="Run scope =&amp;#10;stage-copy?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="2030" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="roster" value="Capture stack member roster&amp;#10;(chassis serials from inventory)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="2140" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="add" value="install add (skipped if already staged) →&amp;#10;track our op-uuid in the operation ledger&amp;#10;to op-complete (state inference fallback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="2236" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_stageadd" value="Run scope =&amp;#10;stage-add?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="2318" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="cfgsync" value="Opt-in: save running-config before reload&amp;#10;(RPC reloads never prompt; detection removed&amp;#10;— SNMP-only source); else a reminder logs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="2428" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="idle" value="Engine-idle gate before EVERY install write:&amp;#10;sys-activity = no-activity on all members&amp;#10;(settle delay only pre-activate w/o signal)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="2524" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="act" value="install activate (non-ISSU, by full internal&amp;#10;version; ledger-tracked,&amp;#10;re-sent on ledger-absent evidence)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="2620" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_act" value="Activation started?&amp;#10;(ledger / state / device drop)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="2702" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="waitc" value="Wait for reload: must observe the device&amp;#10;go DOWN, then boot the target stably&amp;#10;(2 consecutive matching polls)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="2812" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_confirm" value="Target version&amp;#10;stably confirmed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="2894" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="d_members" value="All stack members&amp;#10;rejoined?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="2990" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="rollbackchk" value="Report auto-rollback timer status&amp;#10;(informational; commit follows)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="3100" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="commit" value="install commit → ledger-confirmed,&amp;#10;cross-checked against committed state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="3196" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_commit" value="Commit&amp;#10;succeeded?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="3278" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="sync" value="Sync Nautobot software_version&amp;#10;(warn on fail; already committed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="3388" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="d_remove" value="remove_inactive&amp;#10;enabled?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="275" y="3470" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="remove" value="install remove inactive (idle-gated,&amp;#10;ledger-tracked; warn on fail)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="3580" width="300" height="56" as="geometry"/></mxCell>
        <mxCell id="ok" value="DONE: UPGRADED &amp; COMMITTED ✓" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#2E7D32;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="240" y="3677" width="320" height="54" as="geometry"/></mxCell>
        <mxCell id="d_ip_abort" value="ABORT&amp;#10;No primary IP set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="215" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d_cred_abort" value="ABORT&amp;#10;No Secrets Group / secret missing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="407" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d_reach_abort" value="ABORT&amp;#10;HTTP 401 auth / 403 privilege /&amp;#10;unreachable (RESTCONF disabled?)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="599" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d_target_ok" value="Already on target → no-op if committed;&amp;#10;else install commit (commit-to-be-safe)" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#2E7D32;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="600" y="796" width="330" height="56" as="geometry"/></mxCell>
        <mxCell id="d_floor_abort" value="ABORT&amp;#10;Unknown version, or below the&amp;#10;17.9.1 support floor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="983" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d_mode_abort" value="ABORT&amp;#10;BUNDLE, unrecognized or UNCONFIRMED&amp;#10;mode, or install-oper unreadable&amp;#10;(fail-closed — no override exists)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="1175" width="330" height="66" as="geometry"/></mxCell>
