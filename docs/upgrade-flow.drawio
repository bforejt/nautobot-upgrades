        <mxCell id="mode" value="Read oper-state boot-mode&amp;#10;(install-oper, all members)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="988" width="300" height="56" as="geometry"/></mxCell>
