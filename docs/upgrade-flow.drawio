      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start" value="FOR EACH selected device&amp;#10;(up to &#x27;Parallelism&#x27; concurrently)" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="250" y="31" width="300" height="50" as="geometry"/></mxCell>
        <mxCell id="host" value="Resolve mgmt host&amp;#10;(primary_ip4 / primary_ip)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="250" y="124" width="300" height="56" as="geometry"/></mxCell>
