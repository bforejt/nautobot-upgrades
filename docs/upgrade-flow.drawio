        <mxCell id="d_clean_warn" value="Remove ALL inactive/staged software&amp;#10;(engine-decided; overrides the staged-&amp;#10;conflict stop; failures ABORT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;" vertex="1" parent="1"><mxGeometry x="30" y="1466" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="d_space_abort" value="ABORT&amp;#10;Free space unconfirmed or&amp;#10;insufficient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="1655" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d_dry_ok" value="DONE: DRY-RUN — pre-flight&amp;#10;passed, no changes made" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#2E7D32;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="600" y="1756" width="330" height="56" as="geometry"/></mxCell>
        <mxCell id="d_size_abort" value="ABORT&amp;#10;Copy RPC failed/refused, timed out,&amp;#10;or on-device size ≠ expected — abort" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="1943" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d_size_warn" value="No expected size → warn; rely on&amp;#10;install add signature validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;" vertex="1" parent="1"><mxGeometry x="30" y="1946" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="d_stagecopy_ok" value="DONE: STAGED (copy) — window run&amp;#10;will skip the verified copy" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#2E7D32;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="600" y="2044" width="330" height="56" as="geometry"/></mxCell>
        <mxCell id="d_stageadd_ok" value="DONE: STAGED (add) — marked for&amp;#10;activation; window run: activate →&amp;#10;reload → commit only" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#2E7D32;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="600" y="2332" width="330" height="56" as="geometry"/></mxCell>
        <mxCell id="d_act_abort" value="ABORT&amp;#10;Ledger-recorded failure, or never&amp;#10;registered despite re-sends — abort&amp;#10;(engaged runs get an extended budget)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="2711" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d_confirm_abort" value="ABORT&amp;#10;Not confirmed before timeout — NOT&amp;#10;committed; auto-rollback should revert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="2903" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d_members_abort" value="ABORT&amp;#10;Member(s) missing after reload — NOT&amp;#10;committed; auto-rollback should revert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1"><mxGeometry x="600" y="2999" width="330" height="66" as="geometry"/></mxCell>
