        <mxCell id="e_gates_d_dry" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="gates" target="d_dry"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d_dry_copy" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="d_dry" target="copy"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_copy_d_stage" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="copy" target="d_stage"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d_stage_install" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="d_stage" target="install"><mxGeometry relative="1" as="geometry"/></mxCell>
