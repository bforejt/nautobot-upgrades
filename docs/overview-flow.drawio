<mxfile host="app.diagrams.net" type="device">
  <diagram name="IOS-XE upgrade overview" id="iosxe-upgrade-overview">
    <mxGraphModel dx="1000" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1"
        connect="1" arrows="1" fold="1" page="1" pageScale="1" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start" value="Select devices + target version&amp;#10;(Nautobot → Jobs)" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="160" y="52" width="360" height="52" as="geometry"/></mxCell>
        <mxCell id="gcbefore" value="Opt-in, once per RUN: Golden Config backup of&amp;#10;every target device BEFORE any upgrade starts&amp;#10;(fail-closed: can&#x27;t back up → nothing is touched;&amp;#10;a dry run only reports it)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;dashed=1;" vertex="1" parent="1"><mxGeometry x="140" y="150" width="400" height="72" as="geometry"/></mxCell>
        <mxCell id="connect" value="Connect &amp; authenticate&amp;#10;(RESTCONF over HTTPS, creds from Nautobot Secrets)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="150" y="263" width="380" height="62" as="geometry"/></mxCell>
        <mxCell id="gates" value="Pre-flight gates&amp;#10;≥ 17.9.1 · install mode · image resolved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="150" y="371" width="380" height="62" as="geometry"/></mxCell>
        <mxCell id="d_clean" value="Clean device first&amp;#10;opted in?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="468" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="freespace" value="Free-space gate&amp;#10;(on the cleaned flash when cleaning ran)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="150" y="615" width="380" height="62" as="geometry"/></mxCell>
        <mxCell id="d_dry" value="Dry-run?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="712" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="copy" value="Copy image + verify exact size&amp;#10;(skipped if the file is already on flash)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="150" y="831" width="380" height="62" as="geometry"/></mxCell>
        <mxCell id="d_stagecopy" value="Run scope =&amp;#10;Step 1 (copy) only?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="928" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="add" value="install add — extract &amp; stage the image&amp;#10;(gate → track via the device&#x27;s ledger)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="150" y="1047" width="380" height="62" as="geometry"/></mxCell>
        <mxCell id="d_stageadd" value="Run scope =&amp;#10;Steps 1 &amp; 2&amp;#10;(copy + prep)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="1144" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="d_healthpre" value="Health checks&amp;#10;opted in?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="1252" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="d_savepre" value="Save config before&amp;#10;reload opted in?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="1388" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="activate" value="Activate (non-ISSU) → reload&amp;#10;(gate → track via the device&#x27;s ledger)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="150" y="1535" width="380" height="62" as="geometry"/></mxCell>
        <mxCell id="d_boot" value="Booted the target&amp;#10;&amp; came back healthy?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="1632" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="commit" value="install commit&amp;#10;(gate → track via the device&#x27;s ledger)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="150" y="1751" width="380" height="62" as="geometry"/></mxCell>
        <mxCell id="sync" value="Sync Nautobot software version&amp;#10;(the device record now shows the new OS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B6B7B;" vertex="1" parent="1"><mxGeometry x="150" y="1859" width="380" height="62" as="geometry"/></mxCell>
        <mxCell id="d_savepost" value="Save config after&amp;#10;commit opted in?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="1956" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="d_cleanup" value="Remove inactive&amp;#10;opted in?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E8EEF6;strokeColor=#3C6CA8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="2092" width="250" height="84" as="geometry"/></mxCell>
